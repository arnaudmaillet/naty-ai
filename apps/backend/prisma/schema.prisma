// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- BLOC 1 : IDENTITÉ & ACCÈS ---

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String
  fullName           String
  createdAt          DateTime            @default(now())
  apiKeys            UserApiKey[]
  conversations      Conversation[]
  messageAnnotations MessageAnnotation[]
}

model UserApiKey {
  id           String     @id @default(uuid())
  provider     AiProvider
  encryptedKey String
  isActive     Boolean    @default(true)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, provider])
}

// --- BLOC 2 : CONFIGURATION IA ---

enum AiProvider {
  GEMINI
  OPENAI
  ANTHROPIC
}

model AiModel {
  id            String     @id
  name          String
  provider      AiProvider
  contextWindow Int
  isEnabled     Boolean    @default(true)
  isPublic      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  messages Message[]
}

// --- BLOC 3 : MESSAGERIE & CONTENU ---

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum BlockType {
  TEXT
  CODE
  IMAGE
}

model Conversation {
  id        String    @id @default(uuid())
  title     String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id               String             @id @default(uuid())
  role             MessageRole
  content          String?            @db.Text
  modelId          String?
  aiModel          AiModel?           @relation(fields: [modelId], references: [id])
  conversationId   String
  conversation     Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parentMessageId  String?
  parentMessage    Message?           @relation("Thread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies          Message[]          @relation("Thread")
  annotationId     String?
  originAnnotation MessageAnnotation? @relation(fields: [annotationId], references: [id], onDelete: SetNull)
  blocks           MessageBlock[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([conversationId])
  @@index([parentMessageId])
}

model MessageBlock {
  id          String              @id @default(uuid())
  messageId   String
  message     Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  content     String              @db.Text
  type        BlockType           @default(TEXT)
  order       Int
  annotations MessageAnnotation[]
  createdAt   DateTime            @default(now())
}

model MessageAnnotation {
  id           String       @id @default(uuid())
  blockId      String
  block        MessageBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedText String       @db.Text
  startIndex   Int
  endIndex     Int
  replies      Message[]
  createdAt    DateTime     @default(now())

  @@index([blockId, userId])
}
